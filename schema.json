{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-zA-Z_-]+$"
    },
    "name": {
      "type": "string"
    },
    "force": {
      "type": [ "string", "null" ],
      "enum": [
        null,
        "static",
        "pull",
        "push"
      ]
    },
    "level": {
      "type": "string",
      "enum": [
        "beginner",
        "intermediate",
        "expert"
      ]
    },
    "mechanic": {
      "type": [ "string", "null" ],
      "enum": [
        "isolation",
        "compound",
        null
      ]
    },
    "equipment": {
      "type": [ "string", "null" ],
      "enum": [
        null,
        "medicine ball",
        "dumbbell",
        "body only",
        "bands",
        "kettlebells",
        "foam roll",
        "cable",
        "machine",
        "barbell",
        "exercise ball",
        "e-z curl bar",
        "other"
      ]
    },
    "primaryMuscles": {
      "type": "array",
      "items": [
        {
          "type": "string",
          "enum": [
            "abdominals",
            "abductors",
            "adductors",
            "biceps",
            "calves",
            "chest",
            "forearms",
            "glutes",
            "hamstrings",
            "lats",
            "lower back",
            "middle back",
            "neck",
            "quadriceps",
            "shoulders",
            "traps",
            "triceps"
          ]
        }
      ]
    },
    "secondaryMuscles": {
      "type": "array",
      "items": [
        {
          "type": "string",
          "enum": [
            "abdominals",
            "abductors",
            "adductors",
            "biceps",
            "calves",
            "chest",
            "forearms",
            "glutes",
            "hamstrings",
            "lats",
            "lower back",
            "middle back",
            "neck",
            "quadriceps",
            "shoulders",
            "traps",
            "triceps"
          ]
        }
      ]
    },
    "instructions": {
      "type": "array",
      "items": [
        {
          "type": "string"
        }
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "powerlifting",
        "strength",
        "stretching",
        "cardio",
        "olympic weightlifting",
        "strongman",
        "plyometrics"
      ]
    },
    "images": {
      "type": "array",
      "items": [
        {
          "type": "string"
        }
      ]
    },
    "program": {
      "type": ["array", "null"],
      "description": "Lifelong-UL v3 program-overlay (optional). Absent/null on generic rows. Multiple entries when one exercise fills multiple weekly slots.",
      "items": {
        "type": "object",
        "properties": {
          "slot":         { "type": "string", "pattern": "^(upperA|upperB|lowerA|lowerB)\\.[0-9]+$" },
          "role":         { "type": "string", "enum": ["anchor", "accessory", "carry", "core"] },
          "sets":         { "type": "integer" },
          "reps":         { "type": "string" },
          "rir_ceiling":  { "type": ["integer", "string"] },
          "cap":          { "type": ["string", "null"] },
          "increment":    { "type": "string" },
          "muscle_credit": {
            "type": "object",
            "properties": {
              "primary":   { "type": "object" },
              "secondary": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["chest","back","quads","hamstrings","glutes","side_delts","rear_delts","front_delts","biceps","triceps","calves","hip_abductors","hip_adductors","core","grip_carry"]
                }
              }
            },
            "required": ["primary", "secondary"]
          }
        },
        "required": ["slot", "role", "sets", "reps", "rir_ceiling", "increment", "muscle_credit"]
      }
    }
  },
  "required": [
    "id",
    "name",
    "level",
    "mechanic",
    "equipment",
    "primaryMuscles",
    "secondaryMuscles",
    "instructions",
    "category",
    "images"
  ]
}
